# ============================================================
# SAPDE — Plantilla de variables de entorno
# Copiar a .env y completar con valores reales:
#   Copy-Item .env.example .env
# ============================================================

# --- Base de datos PostgreSQL ---
POSTGRES_USER=sapde_user
POSTGRES_PASSWORD=sapde_password_cambiar
POSTGRES_DB=sapde_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Cadena de conexión (SQLAlchemy construye esta a partir de las vars de arriba)
# DATABASE_URL se puede setear directamente o dejar que config.py la construya
# DATABASE_URL=postgresql://sapde_user:sapde_password@localhost:5432/sapde_db

# --- API FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false          # true sólo en desarrollo (un solo worker)

# --- Dashboard Streamlit ---
DASHBOARD_PORT=8501
DASHBOARD_HOST=0.0.0.0

# --- Rutas de datos y modelos ---
DATA_RAW_PATH=data/raw
DATA_INTERIM_PATH=data/interim
DATA_PROCESSED_PATH=data/processed
MODELS_PATH=models
REPORTS_PATH=reports

# --- Machine Learning ---
RANDOM_SEED=42
N_JOBS=-1                 # hilos para scikit-learn (-1 = todos los núcleos)
TEST_SIZE=0.2             # fracción para conjunto de prueba
SMOTE_SAMPLING=0.5        # ratio de oversampling con SMOTE

# --- Logging ---
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE=logs/sapde.log   # dejar vacío para solo consola

# --- Dataset sintético (Fase 0) ---
SYNTHETIC_N_ESTUDIANTES=1500
SYNTHETIC_SEMILLA=42
